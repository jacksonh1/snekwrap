Bootstrap: docker
From: nvcr.io/nvidia/cuda:12.4.1-cudnn-runtime-ubuntu20.04

%labels
    Maintainer="XBL PEP Design"
    Description="Singularity recipe for RFdiffusion commit e22092420281c644b928e64d490044dfca4f9175"

%help
    This image installs RFdiffusion and pins commit e22092420281c644b928e64d490044dfca4f9175.
    Pre-downloads RFdiffusion model weights into /app/models for offline execution.
    Build:
        apptainer build rf_diffusion.sif rf_diff.apptainer.def
    Run (with GPUs):
        apptainer exec --nv rf_diffusion.sif python3.9 scripts/run_inference.py --help

%environment
    export RFDIFFUSION_HOME=/app/RFdiffusion
    export RFDIFFUSION_MODELS=/app/models
    export DGLBACKEND=pytorch

%post
#!/bin/bash
    set -eu
    export DEBIAN_FRONTEND=noninteractive

    apt-get -q update && \
        apt-get install --no-install-recommends -y git python3.9 python3-pip wget && \
        python3.9 -m pip install --upgrade pip && \
        rm -rf /var/lib/apt/lists/* && \
        apt-get autoremove -y && \
        apt-get clean

    RFDIFFUSION_REPO="https://github.com/RosettaCommons/RFdiffusion.git"
    RFDIFFUSION_COMMIT="e22092420281c644b928e64d490044dfca4f9175"
    RFDIFFUSION_HOME="${RFDIFFUSION_HOME:-/app/RFdiffusion}"
    RFDIFFUSION_MODELS="${RFDIFFUSION_MODELS:-/app/models}"

    mkdir -p /app && \
        git clone "${RFDIFFUSION_REPO}" "${RFDIFFUSION_HOME}" && \
        cd "${RFDIFFUSION_HOME}" && \
        git fetch --depth 1 origin "${RFDIFFUSION_COMMIT}" && \
        git checkout --force "${RFDIFFUSION_COMMIT}" && \
        git submodule update --init --recursive

    mkdir -p "${RFDIFFUSION_MODELS}"
    cd "${RFDIFFUSION_HOME}"
    bash scripts/download_models.sh "${RFDIFFUSION_MODELS}"

    python3.9 -m pip install --no-cache-dir \
        --extra-index-url https://download.pytorch.org/whl/cu121 \
        torch==2.2.2 \
        torchvision==0.17.2 \
        torchaudio==2.2.2

    python3.9 -m pip install --no-cache-dir \
        dgl==1.1.3+cu121 -f https://data.dgl.ai/wheels/cu121/repo.html

    python3.9 -m pip install --no-cache-dir \
        numpy==1.26.4 \
        e3nn==0.5.1 \
        wandb==0.12.0 \
        pynvml==11.0.0 \
        git+https://github.com/NVIDIA/dllogger#egg=dllogger \
        decorator==5.1.0 \
        hydra-core==1.3.2 \
        pyrsistent==0.19.3 \
        pydantic==1.10.19 \
        pandas==2.3.3

    python3.9 -m pip install --no-cache-dir "${RFDIFFUSION_HOME}/env/SE3Transformer"
    python3.9 -m pip install --no-cache-dir "${RFDIFFUSION_HOME}" --no-deps

    chmod -R a+rwX "${RFDIFFUSION_HOME}" "${RFDIFFUSION_MODELS}"

%runscript
    cd /app/RFdiffusion
    exec python3.9 scripts/run_inference.py "$@"
